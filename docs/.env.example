ASSEMBLYAI_API_KEY=
TEACHER_TRANSCRIPTION_PROVIDER=assemblyai
TRANSCRIPTION_PROVIDER=assemblyai
STT_PROVIDER=openai
STT_MODEL=whisper-1

# Backblaze B2 object storage for Railway production.
# Use STORAGE_BACKEND=local for local development.
STORAGE_BACKEND=s3
S3_PROVIDER=backblaze
S3_BUCKET_NAME=parallea-media
S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
S3_REGION=us-west-004
S3_ACCESS_KEY_ID=your_backblaze_key_id
S3_SECRET_ACCESS_KEY=your_backblaze_application_key
S3_PUBLIC_BASE_URL=
S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

DATA_DIR=/app/data
TMP_DIR=/app/data/tmp
MANIM_RUNTIME_DIR=/app/data/manim_runtime
GENERATED_MEDIA_TTL_SECONDS=3600
DELETE_GENERATED_MEDIA_AFTER_PLAYBACK=true
# creative_safe renders OpenAI-generated Manim directly after hard safety checks.
# strict_layout forces region/panel helpers; fallback_only uses simple local fallback scenes.
MANIM_VISUAL_STYLE=creative_safe
MAX_MANIM_VISUAL_DURATION_SECONDS=90
MIN_ABSOLUTE_MANIM_DURATION_SECONDS=20
MIN_VISUAL_TO_AUDIO_DURATION_RATIO=0.35
AV_SYNC_DURATION_REPAIR_ENABLED=false
ROADMAP_PART_MATCH_THRESHOLD=0.45

# Railway still needs a writable local temp directory or volume for Manim work.
# Permanent uploaded videos, thumbnails, generated Manim MP4s, and TTS MP3s
# are stored differently:
# - teacher uploaded videos remain permanent in Backblaze B2/S3 when STORAGE_BACKEND=s3.
# - generated Manim MP4s and generated TTS MP3s are temporary and use temp/*
#   object prefixes or TMP_DIR local paths.
# - TTL cleanup removes generated media for abandoned sessions.
# Use a bucket-scoped Backblaze application key with read/write/list permissions,
# not the master key. Leave S3_PUBLIC_BASE_URL empty for private bucket access
# through presigned URLs.
